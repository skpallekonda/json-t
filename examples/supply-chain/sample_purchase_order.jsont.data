        { "500 Supplier Way", null, "Chicago", "IL", "60601", "US" }
      }
    ],

    // LineItems (PO1 + REF + DTM)
    [
      {
        // PO1: Line Item 1 — Laptop Computers
        { "001", 50.0, EA, 899.99, null, BUYER_PART, "LAPTOP-PRO-15", VENDOR_PART, "TP-LP-15-2026" },
