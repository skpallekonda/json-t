    "ZZ", "ACME-BUYER     ", "ZZ", "VENDOR-CORP    ",
    "2026-04-21", "09:15:00", "00401",
    100000001, "0", "P", ":"
  },

  // GS: Functional Group Header
  // Fields: functionalCode, senderCode, receiverCode, groupDate, groupTime,
